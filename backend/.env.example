# ─── Database ───────────────────────────────────────────────
# PostgreSQL connection string for production (pooler-friendly)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&pgbouncer=true&connection_limit=5"

# ─── Auth ────────────────────────────────────────────────────
# Generate a strong secret: node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=your-very-long-random-secret-here
JWT_EXPIRES_IN=7d

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
FRONTEND_URL=https://your-frontend-domain.com
